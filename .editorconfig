# dotnet_naming_symbols.types.applicable_accessibilities = public, internal, private, protected, protected_internal, private_protected
# dotnet_naming_symbols.types.required_modifiers =

# dotnet_naming_symbols.non_field_members.applicable_kinds = property, event, method
# dotnet_naming_symbols.non_field_members.applicable_accessibilities = public, internal, private, protected, protected_internal, private_protected
# dotnet_naming_symbols.non_field_members.required_modifiers =

# dotnet_naming_symbols.constant_symbols.applicable_kinds = field
# dotnet_naming_symbols.constant_symbols.required_modifiers = const

# dotnet_naming_symbols.static_readonly_private_symbols.applicable_kinds = field
# dotnet_naming_symbols.static_readonly_private_symbols.applicable_accessibilities = private, protected
# dotnet_naming_symbols.static_readonly_private_symbols.required_modifiers = static, readonly

# dotnet_naming_symbols.private_fields_symbols.applicable_kinds = field
# dotnet_naming_symbols.private_fields_symbols.applicable_accessibilities = private, protected

# dotnet_naming_symbols.method_and_property_symbols.applicable_kinds = method, property, event, class, struct, enum
# dotnet_naming_symbols.method_and_property_symbols.applicable_accessibilities = public, internal, friend, protected

# Naming styles
# dotnet_naming_style.pascal_case.required_prefix =
# dotnet_naming_style.pascal_case.required_suffix =
# dotnet_naming_style.pascal_case.word_separator =
# dotnet_naming_style.pascal_case.capitalization = pascal_case

# dotnet_naming_style.begins_with_i.required_prefix = I
# dotnet_naming_style.begins_with_i.required_suffix =
# dotnet_naming_style.begins_with_i.word_separator =
# dotnet_naming_style.begins_with_i.capitalization = pascal_case

# dotnet_naming_style.prefix_underscore_style.capitalization = camel_case
# dotnet_naming_style.prefix_underscore_style.required_prefix = _

# dotnet_naming_style.upper_snake_case_style.capitalization = all_upper
# dotnet_naming_style.upper_snake_case_style.word_separator = _

# dotnet_naming_style.pascal_case_style.capitalization = pascal_case

#### Supress annoying warnings ####

# Do not use insecure randomness - don't care in this project
dotnet_diagnostic.CA5394.severity = none

# Do not expose generic lists
dotnet_diagnostic.CA1002.severity = none

# Use generic event handler instances
dotnet_diagnostic.CA1003.severity = none

# Namespace does not match folder structure
dotnet_diagnostic.IDE0130.severity = none

# Validate arguments of public methods
# dotnet_diagnostic.CA1062.severity = none

# Property names should not match get methods
# dotnet_diagnostic.CA1721.severity = none

# Do not directly await a Task - conflicts with Godot
dotnet_diagnostic.CA2007.severity = none

# Do not catch general exception types - I can decide for myself, thanks
dotnet_diagnostic.CA1031.severity = none

# Do not declare static members on generic types - I can decide for myself, thanks
dotnet_diagnostic.CA1000.severity = none

# For now, the null noise is too much
dotnet_diagnostic.CA1062.severity = none
dotnet_diagnostic.CS8618.severity = none
dotnet_diagnostic.CS8604.severity = none
dotnet_diagnostic.CS8603.severity = none
dotnet_diagnostic.CS8602.severity = none

# Collection properties should be read only
dotnet_diagnostic.CA2227.severity = none

# Do not raise reserved exception types
dotnet_diagnostic.CA2201.severity = none

# Do not initialize unnecessarily
dotnet_diagnostic.CA1805.severity = none

# Operator overloads have named alternates - a relic
dotnet_diagnostic.CA2225.severity = none

# Identifiers should not contain underscores - I want all my const in CAPS_SNAKE
dotnet_diagnostic.CA1707.severity = none

# Call GC.SuppressFinalize correctly
dotnet_diagnostic.CA1816.severity = none
