# dotnet_naming_rule.types_should_be_pascal_case.style = pascal_case

# dotnet_naming_rule.non_field_members_should_be_pascal_case.severity = suggestion
# dotnet_naming_rule.non_field_members_should_be_pascal_case.symbols = non_field_members
# dotnet_naming_rule.non_field_members_should_be_pascal_case.style = pascal_case

# dotnet_naming_rule.constants_must_be_upper_snake.symbols = constant_symbols
# dotnet_naming_rule.constants_must_be_upper_snake.style = upper_snake_case_style
# dotnet_naming_rule.constants_must_be_upper_snake.severity = warning

# dotnet_naming_rule.static_readonly_private_fields.symbols = static_readonly_private_symbols
# dotnet_naming_rule.static_readonly_private_fields.style = prefix_underscore_style
# dotnet_naming_rule.static_readonly_private_fields.severity = warning

# dotnet_naming_rule.private_fields_with_underscore.symbols = private_fields_symbols
# dotnet_naming_rule.private_fields_with_underscore.style = prefix_underscore_style
# dotnet_naming_rule.private_fields_with_underscore.severity = warning

# dotnet_naming_rule.members_pascal_case.symbols = method_and_property_symbols
# dotnet_naming_rule.members_pascal_case.style = pascal_case_style
# dotnet_naming_rule.members_pascal_case.severity = warning

# Symbol specifications
# dotnet_naming_symbols.interface.applicable_kinds = interface
# dotnet_naming_symbols.interface.applicable_accessibilities = public, internal, private, protected, protected_internal, private_protected
# dotnet_naming_symbols.interface.required_modifiers =

